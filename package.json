{
  "name": "rythmfmforlinux",
  "productName": "rythmfmforlinux",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "app:clean": "rm -r .vite; rm -r dist",
    "app:dir": "electron-builder --dir",
    "app:dist": "electron-builder",
    "app:linux:resources": "cp -r ./injects ./dist/linux-unpacked/resources/; cp -r ./css ./dist/linux-unpacked/resources/; cp -r ./config ./dist/linux-unpacked/resources/; cp -r ./modules ./dist/linux-unpacked/resources/"
  },
  "build": {
      "appId": "sh.thered.RythmForLinux"
  },
  "keywords": [],
  "author": {
    "name": "TheRedXD",
    "email": "redprogamingtv@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.0.0",
    "electron": "41.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.12"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
